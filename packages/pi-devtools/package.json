{
  "name": "@zenspc/pi-devtools",
  "version": "0.2.1",
  "description": "Context usage report, cwd switching (/cd), and richer session footer for Pi",
  "keywords": [
    "pi-package",
    "pi-extension",
    "devtools",
    "context",
    "cwd",
    "cd"
  ],
  "license": "MIT",
  "author": "dhairya-rathod",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zenspc/pi-extensions.git",
    "directory": "packages/pi-devtools"
  },
  "bugs": {
    "url": "https://github.com/zenspc/pi-extensions/issues"
  },
  "homepage": "https://github.com/zenspc/pi-extensions/tree/master/packages/pi-devtools#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "extensions",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "scripts": {
    "prepack": "cp --remove-destination ../../LICENSE LICENSE",
    "postpack": "ln -sfn ../../LICENSE LICENSE"
  }
}
